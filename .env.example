# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=

# Farcaster
# Your production domain (no protocol, no trailing slash)
FARCASTER_DOMAIN=
# Generate accountAssociation at https://farcaster.xyz/~/developers/mini-apps/manifest
FARCASTER_ACCOUNT_HEADER=
FARCASTER_ACCOUNT_PAYLOAD=
FARCASTER_ACCOUNT_SIGNATURE=
# Neynar API key (from neynar.com dashboard)
NEYNAR_API_KEY=
NEYNAR_CLIENT_ID=
# Webhook URL from Neynar dashboard
FARCASTER_WEBHOOK_URL=

# Base / Coinbase
# Client API key for RPC access (from portal.cdp.coinbase.com)
NEXT_PUBLIC_ONCHAINKIT_API_KEY=
# CDP SDK keys (server-side only, for wallet operations)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
NEXT_PUBLIC_BASE_APP_NAME=BonkWithClaude

# General
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app
