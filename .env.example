# Telegram
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Secret for HMAC validation of initData (optional, for additional security)
TELEGRAM_BOT_SECRET=

# Farcaster
# Your production domain (no protocol, no trailing slash)
FARCASTER_DOMAIN=bonkwithclaude.vercel.app
# Generate accountAssociation at https://farcaster.xyz/~/developers/mini-apps/manifest
FARCASTER_ACCOUNT_HEADER=
FARCASTER_ACCOUNT_PAYLOAD=
FARCASTER_ACCOUNT_SIGNATURE=

# Base
# Get from https://dashboard.base.org
BASE_API_KEY=
NEXT_PUBLIC_BASE_APP_NAME=BonkWithClaude

# General
# Your production URL (with protocol, no trailing slash)
NEXT_PUBLIC_APP_URL=https://bonkwithclaude.vercel.app
